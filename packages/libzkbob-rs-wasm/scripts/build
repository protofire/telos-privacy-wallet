#!/usr/bin/env bash

set -e

# Toolchain configuration
# Note: Ensure these versions are available; 1.84+ are current as of 2025.
RUSTUP_MT_TOOLCHAIN=nightly-2025-01-01  # Example for recent nightly
RUSTUP_ST_TOOLCHAIN=stable              # Standard stable
PARENT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." &> /dev/null && pwd )"

# 1. New function to prepare the environment automatically
function prepare_env () {
    echo "--- Preparing Build Environment ---"

    # Install jq if missing
    if ! command -v jq &> /dev/null; then
        echo "Installing jq..."
        sudo apt-get update && sudo apt-get install -y jq
    fi

    # Ensure rustup is installed
    if ! command -v rustup &> /dev/null; then
        echo "Installing rustup..."
        curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
        source "$HOME/.cargo/env"
    fi

    echo "Installing toolchains: $RUSTUP_ST_TOOLCHAIN and $RUSTUP_MT_TOOLCHAIN..."
    rustup toolchain install $RUSTUP_ST_TOOLCHAIN
    rustup toolchain install $RUSTUP_MT_TOOLCHAIN

    echo "Adding wasm32 targets..."
    rustup target add wasm32-unknown-unknown --toolchain $RUSTUP_ST_TOOLCHAIN
    rustup target add wasm32-unknown-unknown --toolchain $RUSTUP_MT_TOOLCHAIN

    echo "Installing rust-src for nightly (required for -Z build-std)..."
    rustup component add rust-src --toolchain $RUSTUP_MT_TOOLCHAIN

    # Install wasm-pack if missing
    if ! command -v wasm-pack &> /dev/null; then
        echo "Installing wasm-pack..."
        curl https://rustwasm.github.io/wasm-pack/installer/init.sh -sSf | sh
    fi

    # Install wasm-opt if missing (part of binaryen)
    if ! command -v wasm-opt &> /dev/null; then
        echo "Installing binaryen (wasm-opt)..."
        sudo apt-get update && sudo apt-get install -y binaryen
    fi
    
    echo "--- Environment Ready ---"
}

function patch_package_json () {
  echo "Patching package.json for $1..."
  sed -i.bak -E "s/\"name\": \"libzkbob-rs-wasm\"/\"name\": \"libzkbob-rs-wasm-$1\"/g" "$PARENT_DIR/$1/package.json"
  jq '.files |= . + ["snippets"]' "$PARENT_DIR/$1/package.json" > "$PARENT_DIR/$1/tmp.json" \
    && mv "$PARENT_DIR/$1/tmp.json" "$PARENT_DIR/$1/package.json"
}

# build $name $features $is_mt 
function build () {
  echo "Building $1 (MT: $3)..."
  if [ "$3" = true ] ; then	
    # Export RUSTFLAGS to ensure wasm-bindgen-rayon sees them
    export RUSTFLAGS='-C target-feature=+atomics,+bulk-memory,+mutable-globals'
    rustup run $RUSTUP_MT_TOOLCHAIN \
      wasm-pack build --release --target web -d "$PARENT_DIR/$1" \
      -- --features "$2" -Z build-std=panic_abort,std	
  else
    export RUSTFLAGS=''
    rustup run $RUSTUP_ST_TOOLCHAIN \
      wasm-pack build --release --target web -d "$PARENT_DIR/$1" -- --features "$2"	
  fi

  patch_package_json "$1"
}

# --- Main Execution ---
prepare_env

# 2. Run the builds
# build [folder_name] [features] [is_multicore] 
build web web false
build web-mt web,multicore true

echo "Builds completed successfully!"
